{
  "name": "@apiframe-ai/sdk",
  "version": "2.0.0-beta.1",
  "description": "Official Node.js SDK for the Apiframe v2 API — unified image, video and music generation across 60+ AI models.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./webhooks": {
      "types": "./dist/webhooks.d.ts",
      "import": "./dist/webhooks.js",
      "require": "./dist/webhooks.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "openapi.json",
    "README.md",
    "MIGRATION.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "sync": "tsx scripts/sync-openapi.ts",
    "prebuild": "rm -rf dist",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "tsc --noEmit",
    "lint": "eslint src test",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "apiframe",
    "ai",
    "image-generation",
    "video-generation",
    "music-generation",
    "midjourney",
    "flux",
    "kling",
    "veo",
    "sora",
    "suno",
    "sdk",
    "api",
    "client"
  ],
  "author": "Apiframe <support@apiframe.ai> (https://apiframe.ai)",
  "license": "MIT",
  "homepage": "https://github.com/apiframe-ai/apiframe-nodejs-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apiframe-ai/apiframe-nodejs-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/apiframe-ai/apiframe-nodejs-sdk/issues"
  },
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "openapi-typescript": "^7.5.2",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "undici": "^7.2.0",
    "vitest": "^2.1.8"
  }
}
